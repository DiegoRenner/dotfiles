[font]
size = 12.0

[font.bold]
family = "Hack Nerd Font Mono"
style = "Bold"

[font.bold_italic]
family = "Hack Nerd Font Mono"
style = "Bold Italic"

[font.italic]
family = "Hack Nerd Font Mono"
style = "Italic"

[font.normal]
family = "Hack Nerd Font Mono"
style = "Regular"

[window]
opacity = {{ .colors.opacity }}
blur = true

[colors.primary]
background = "{{ .colors.bg }}"
foreground = "{{ .colors.fg }}"

[colors.cursor]
text = "{{ .colors.bg }}"
cursor = "{{ .colors.accent }}"
