[general]
status_path = "~/.local/share/vdirsyncer/status/"

[pair my_calendar]
a = "my_calendar_local"
b = "my_calendar_remote"
collections = ["from a", "from b"]
metadata = ["displayname", "color"]

[storage my_calendar_local]
type = "filesystem"
path = "~/.local/share/calendars/"
fileext = ".ics"

[storage my_calendar_remote]
type = "caldav"
url = "https://rhub.hopto.org/remote.php/dav"
username = "Admin"
password.fetch = ["command", "cat", "/home/diego/.config/vdirsyncer/password"]
