/**
 * ROFI SQUARED THEME - Readability Fix
 **/

* {
    font:   "Hack Nerd Font Mono 12";

    bg0:     rgba({{ .colors.bg_rgb }}, {{ .colors.opacity }});
    bg1:     rgba({{ .colors.bg_rgb }}, 0.5);
    fg0:     {{ .colors.fg }};

    accent-color:     {{ .colors.accent }};
    urgent-color:     {{ .colors.red }};

    background-color:   transparent;
    text-color:         @fg0;

    margin:     0;
    padding:    0;
    spacing:    0;
}

window {
    location:   center;
    anchor:     center;
    width:      600;

    background-color:   @bg0;
    border:             1px solid;
    border-color:       @accent-color;
}

mainbox {
    padding:    10px;
    children:   [ inputbar, listview ];
}

inputbar {
    spacing:    10px;
    padding:    10px;
    background-color:   @bg1;
}

prompt, entry, element-icon, element-text {
    vertical-align: 0.5;
}

prompt {
    text-color: @accent-color;
}

entry {
    placeholder: "Search...";
    placeholder-color: rgba(253, 246, 227, 0.3);
}

listview {
    padding:    5px 0;
    lines:      10;
    columns:    1;
    fixed-height:   false;
}

element {
    padding:    8px 12px;
    spacing:    10px;
    background-color: transparent;
    text-color: @fg0;
}

/* Fix for unreadable alternate rows */
element normal normal, element alternate normal {
    background-color: transparent;
    text-color: @fg0;
}

element selected normal, element selected active {
    background-color:   rgba({{ .colors.accent_rgb }}, 0.2);
    text-color:         @accent-color;
    border:             0px 0px 0px 4px solid;
    border-color:       @accent-color;
}

element-icon {
    size:   1.2em;
}

element-text {
    text-color: inherit;
}
